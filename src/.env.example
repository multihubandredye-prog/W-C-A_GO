# Configurações da Aplicação
# Porta onde o servidor da API irá rodar (Ex: 3000)
APP_PORT=3000
# Host onde o servidor irá escutar (0.0.0.0 para todas as interfaces)
APP_HOST=0.0.0.0
# Se true, ativa logs de depuração detalhados
APP_DEBUG=false
# Nome do sistema operacional que aparecerá no WhatsApp Web (Ex: Chrome, GOWA)
APP_OS=Chrome
# Credenciais para Autenticação Básica nas rotas da API (formato: usuario:senha,usuario2:senha2)
APP_BASIC_AUTH=user1:pass1,user2:pass2
# Caminho base opcional para as rotas da API
APP_BASE_PATH=
# Redes/IPs de proxies confiáveis (Ex: 0.0.0.0/0 para confiar em todos)
APP_TRUSTED_PROXIES=0.0.0.0/0

# Configurações do Banco de Dados
# URI de conexão com o banco de dados principal (SQLite)
DB_URI=file:storages/whatsapp.db?_foreign_keys=on
# URI opcional para o banco de chaves (se separado)
DB_KEYS_URI=

# Configurações do WhatsApp
# Mensagem de resposta automática para mensagens recebidas (se preenchido)
WHATSAPP_AUTO_REPLY="Auto reply message"
# Se true, marca mensagens recebidas como lidas automaticamente
WHATSAPP_AUTO_MARK_READ=false
# Se true, rejeita chamadas recebidas automaticamente
WHATSAPP_AUTO_REJECT_CALL=false
# Se true, baixa automaticamente arquivos de mídia recebidos
WHATSAPP_AUTO_DOWNLOAD_MEDIA=true
# URLs de Webhook para onde os eventos serão enviados (separados por vírgula)
WHATSAPP_WEBHOOK=https://webhook.site/07b69616-5943-4c7f-a8be-db4819df699e,https://webhook.site/09a38aff-d11a-4a38-a176-3f3efa0b5e8b
# Chave secreta para validar a assinatura do webhook
WHATSAPP_WEBHOOK_SECRET=super-secret-key
# Se true, ignora a verificação de certificados TLS do webhook (inseguro)
WHATSAPP_WEBHOOK_INSECURE_SKIP_VERIFY=false
# Lista de eventos que serão enviados ao webhook (separados por vírgula)
WHATSAPP_WEBHOOK_EVENTS=message,message.reaction,message.revoked,message.edited,message.ack,message.deleted,group.participants
# Se true, envia eventos de mensagens enviadas por você ao webhook
WHATSAPP_WEBHOOK_INCLUDE_OUTGOING=false
# Se true, valida se o número da conta WhatsApp é válido ao conectar
WHATSAPP_ACCOUNT_VALIDATION=true
# Status de presença ao conectar (available, unavailable, none)
WHATSAPP_PRESENCE_ON_CONNECT=unavailable
# Se true, envia pulsos de presença "disponível" periodicamente
WHATSAPP_PRESENCE_PULSE_ENABLED=true
# Intervalo entre os pulsos de presença
WHATSAPP_PRESENCE_PULSE_INTERVAL=24h
# Duração de cada pulso de presença
WHATSAPP_PRESENCE_PULSE_DURATION=5m
# Se true, habilita o armazenamento local do histórico de mensagens no banco de dados
WHATSAPP_CHAT_STORAGE=true

# Configurações de Limpeza de Mídia
# Se true, habilita a exclusão automática de arquivos de mídia temporários
AUTO_DELETE_MEDIA=true
# Tempo em SEGUNDOS para manter um arquivo de mídia antes de ser removido pela limpeza automática
# Exemplo: 300 para 5 minutos, 60 para 1 minuto.
AUTO_DELETE_MEDIA_DURATION=300

# Integração com Chatwoot
# Se true, habilita a integração com o Chatwoot
CHATWOOT_ENABLED=false
# URL da sua instância do Chatwoot
CHATWOOT_URL=https://app.chatwoot.com
# Token de API do Chatwoot
CHATWOOT_API_TOKEN=xxxxxxxx
# ID da conta no Chatwoot
CHATWOOT_ACCOUNT_ID=111111
# ID da caixa de entrada (inbox) no Chatwoot
CHATWOOT_INBOX_ID=000000
# ID do dispositivo opcional para mensagens de saída
CHATWOOT_DEVICE_ID=
# Se true, importa mensagens de histórico ao Chatwoot
CHATWOOT_IMPORT_MESSAGES=false
# Limite de dias de histórico para importar
CHATWOOT_DAYS_LIMIT_IMPORT_MESSAGES=3
